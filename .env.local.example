# Copy this file to ".env.local" and fill in your values.
# The site works WITHOUT these (it shows sample data), but to let your dad
# save real schedule/announcements you need a free Supabase project.

# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# The password your dad types on the /admin page. Change this to anything.
ADMIN_PASSWORD=choose-a-password-here

# OPTIONAL — email alerts when a customer submits the "Book Us" form.
# Sign up free at https://resend.com, create an API key, paste it here.
# Leave blank to disable email (bookings still save to the dashboard).
RESEND_API_KEY=
BOOKING_NOTIFY_EMAIL=mcdonoughga@donutnv.com
