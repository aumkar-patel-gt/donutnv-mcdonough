# Copy this file to ".env.local" and fill in your values.
# The site works WITHOUT these (it shows sample data), but to let your dad
# save real schedule/announcements you need a free Supabase project.

# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# The password your dad types on the /admin page. Change this to anything.
ADMIN_PASSWORD=choose-a-password-here
